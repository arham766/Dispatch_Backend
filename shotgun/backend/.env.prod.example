# ────────────────────────────────────────────────────────────────
# Shotgun / Dispatch — PRODUCTION environment template (Render)
#
# Copy each value into Render's Environment tab on the backend
# service. Do NOT check in the filled version of this file.
#
# Differences vs .env.example (dev):
#   - KIRO_MODE shifts from "desktop" → the composite Action does
#     the patching; the backend is a coordinator + WS hub
#   - KANE_FAST_MODE stays true (production-grade Kane in CI)
#   - LOCAL_PREVIEW_URL is removed; PREVIEW_BASE_URL is set by the
#     Action per-run
#   - DATABASE_URL is required (Render Postgres add-on)
#   - PUBLIC_APP_URL is the Render hostname
#   - All callback/webhook URLs reference the public hostname
# ────────────────────────────────────────────────────────────────

# ── Kane CLI ──────────────────────────────────────
LT_USERNAME=YOUR_TESTMUAI_USERNAME
LT_ACCESS_KEY=YOUR_TESTMUAI_KEY
KANE_HEADLESS=true
KANE_FAST_MODE=true

# ── Targets (replaced per-tenant per-run; these are fallbacks) ──
STAGING_BASE_URL=
# In prod the Action sets PREVIEW_BASE_URL per run, so there's
# no LOCAL_PREVIEW_URL fallback here.

# ── Kiro (the patcher) ─────────────────────────────
# In multi-tenant cloud, "kiro" is whatever the composite Action
# uses to write the fix (hosted patcher API). The orchestrator
# only coordinates; KIRO_MODE here selects the no-op coordinator.
KIRO_MODE=hook
KIRO_WORKDIR=/tmp
KIRO_TRIGGER_FILE=.shotgun/trigger.json

# ── GitHub PAT — admin-only fallback ─────────────
# Most users sign in with GitHub OAuth (Firebase provider) and the
# backend gets their access token from the ID-token claims. The PAT
# here is only for admin demo repos.
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BASE_BRANCH=main

# ── Orchestrator ──────────────────────────────────
RETRY_BUDGET=4
CONFIRMATION_RUNS=2
KANE_TIMEOUT_SECONDS=180

# ── Recording ────────────────────────────────────
# In prod we still write to disk for fast local replay, but the
# durable truth lives in Postgres + S3 (incidents + artifacts).
RECORD_LOOPS=true
RECORDINGS_DIR=/var/data/recordings
RECORD_RETENTION=200
RECORD_INDEX_FILE=/var/data/recordings/index.json

# ── Kane Review ──────────────────────────────────
KANE_REVIEW_ENABLED=true
KANE_REVIEW_MODE=chained
KANE_REVIEW_BUDGET=2
KANE_REVIEW_BLOCK_ON_REGRESSION=true
KANE_REVIEW_FLOWS_DIR=/var/data/flows
KANE_REVIEW_CARRY_FORWARD=true
KANE_REVIEW_POST_AS=review

# ── Intake ───────────────────────────────────────
# webhook in prod (GitHub deployment_status + workflow_run drive
# the loop; manual button still works via /api/github/repos/{id}/trigger).
INTAKE_MODE=webhook

# ── Postgres (Render add-on) ─────────────────────
# Render provides this automatically when you attach a Postgres
# database to the service. The format is:
#   postgresql://USER:PASS@HOST:5432/DB
DATABASE_URL=

# ── AgentPhone ───────────────────────────────────
AGENTPHONE_ENABLED=true
AGENTPHONE_API_URL=https://api.agentphone.ai
AGENTPHONE_API_KEY=
AGENTPHONE_AGENT_ID=
AGENTPHONE_FROM_NUMBER_ID=
ONCALL_PHONE=
AGENTPHONE_FROM=
AGENTPHONE_NO_ANSWER_TIMEOUT=45

# ── Resend ───────────────────────────────────────
# For real prod, set up a custom verified sending domain:
#   https://resend.com/domains
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
RESEND_NOTIFY=
RESEND_ENABLED=true

# ── Firebase Admin ───────────────────────────────
# On Render, prefer the JSON blob over a file path so the secret
# is in Render's secrets store, not the file system.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_FILE=
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── GitHub App ───────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=

# ── Public URL ───────────────────────────────────
# Your Render hostname. Replace AFTER first deploy.
PUBLIC_APP_URL=https://shotgun-backend.onrender.com

# ── Admin ────────────────────────────────────────
ADMIN_EMAILS=
DEMO_REPO_FULL_NAME=
DEMO_REPO_DEPLOY_URL=
DEMO_REPO_LOCAL_LOOP=false

# -- GitHub Token for Kiro Agent Push -------------
GITHUB_TOKEN=

