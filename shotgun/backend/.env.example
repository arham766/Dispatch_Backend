# ────────────────────────────────────────────────────────────────
# Shotgun / Dispatch — backend environment template
#
# Copy to .env and fill in real values. Never commit .env.
# For production deploy on Render, see .env.prod.example and the
# render.yaml at the repo root.
# ────────────────────────────────────────────────────────────────

# ── Kane CLI (LambdaTest) ──────────────────────────
LT_USERNAME=
LT_ACCESS_KEY=
KANE_HEADLESS=true
# Fast smoke mode: REPRODUCE/VERIFY/CONFIRM use a 2-sec curl + Node
# DOM probe instead of full Kane CLI. Real Kane still runs once
# before SHIP for the audit-grade artifact. Set false to use Kane
# CLI for every step (slow but maximally rigorous).
KANE_FAST_MODE=true

# ── App under test ────────────────────────────────
STAGING_BASE_URL=http://localhost:3001
# When the orchestrator needs to test a patched branch, it falls
# back to LOCAL_PREVIEW_URL (no preview deploy in dev). In prod
# this is replaced by the composite Action's PREVIEW_BASE_URL after
# a real preview deploy.
LOCAL_PREVIEW_URL=http://localhost:3001

# ── Kiro (the patcher) ─────────────────────────────
# desktop = local Kiro IDE (admin demo). For multi-tenant cloud,
# the composite GitHub Action calls a hosted patcher instead.
KIRO_MODE=desktop
KIRO_WORKDIR=./app-under-test
KIRO_TRIGGER_FILE=.shotgun/trigger.json

# ── GitHub (PAT — admin/local-loop fallback) ──────
# For multi-tenant cloud use the GitHub App below. For admin
# demos this PAT is what github_pr.py and the workflow committer
# fall back to. Scopes needed: repo, workflow.
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BASE_BRANCH=main

# ── Orchestrator ──────────────────────────────────
RETRY_BUDGET=4
CONFIRMATION_RUNS=2
KANE_TIMEOUT_SECONDS=120

# ── Recording ────────────────────────────────────
RECORD_LOOPS=true
RECORDINGS_DIR=./recordings
RECORD_RETENTION=50
RECORD_INDEX_FILE=./recordings/index.json

# ── Kane Review (chained PR review) ──────────────
KANE_REVIEW_ENABLED=false
KANE_REVIEW_MODE=chained
KANE_REVIEW_BUDGET=2
KANE_REVIEW_BLOCK_ON_REGRESSION=true
KANE_REVIEW_FLOWS_DIR=./flows
KANE_REVIEW_CARRY_FORWARD=true
KANE_REVIEW_POST_AS=review

# ── Intake (Kafka / webhook) ─────────────────────
INTAKE_MODE=webhook

# ── Datastore (Postgres) ─────────────────────────
# Required in production for multi-tenant durability. In dev,
# leaving this empty falls back to JSON files under ./data/.
DATABASE_URL=

# ── AgentPhone (voice) ───────────────────────────
AGENTPHONE_ENABLED=true
AGENTPHONE_API_URL=https://api.agentphone.ai
AGENTPHONE_API_KEY=
# The AgentPhone agent that places the call. Create one at
# agentphone.ai/agents and copy its id here. Per-call we override
# the system prompt so the agent fits the Shotgun voice.
AGENTPHONE_AGENT_ID=
AGENTPHONE_FROM_NUMBER_ID=
# E.164 — destination phone for the on-call engineer (admin demo).
# In multi-tenant prod this comes from the user profile.
ONCALL_PHONE=
AGENTPHONE_FROM=
AGENTPHONE_NO_ANSWER_TIMEOUT=45

# ── Resend (transactional email) ─────────────────
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
RESEND_NOTIFY=
RESEND_ENABLED=true

# ── Firebase Admin (server-side token verify) ─────
# Either point to a JSON file on disk (FIREBASE_SERVICE_ACCOUNT_FILE)
# OR paste the whole service-account JSON inline (FIREBASE_SERVICE_ACCOUNT_JSON).
# On Render the inline blob is easier.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_FILE=
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── GitHub App (multi-tenant) ─────────────────────
# Register once via /api/github/manifest. The exchange endpoint
# auto-writes these vars back to .env on first registration.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=

# ── Public app URL (used in OAuth callbacks + emails) ──
# Dev: http://localhost:3000
# Prod: https://your-render-app.onrender.com
PUBLIC_APP_URL=http://localhost:3000

# ── Admin allowlist ──────────────────────────────
# Comma-separated emails that bypass GitHub App onboarding and get
# a pre-monitored demo repo wired through the existing PAT.
ADMIN_EMAILS=
DEMO_REPO_FULL_NAME=
DEMO_REPO_DEPLOY_URL=
DEMO_REPO_LOCAL_LOOP=true

# -- GitHub Token for Kiro Agent Push -------------
GITHUB_TOKEN=

